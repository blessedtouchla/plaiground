<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PLAIGROUND • Wanna Plai</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        body {
            font-family: 'Inter', system_ui, sans-serif;
        }
    </style>
</head>
<body class="bg-white">
    <!-- Navbar -->
    <nav class="border-b">
        <div class="max-w-6xl mx-auto px-6 py-5 flex justify-between items-center">
            <div class="flex items-center gap-x-3">
                <span class="font-bold text-3xl tracking-tight">PLAIGROUND</span>
            </div>
            
            <div class="flex items-center gap-x-8 text-sm font-medium">
                <a href="#" class="hover:text-orange-600 transition-colors">Explore</a>
                <a href="#" class="hover:text-orange-600 transition-colors">How it Works</a>
                <button onclick="document.getElementById('create-section').scrollIntoView({ behavior: 'smooth' })" 
                        class="px-6 py-2.5 rounded-2xl bg-black text-white text-sm font-semibold hover:bg-zinc-800 transition-all">
                    Start Creating
                </button>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="max-w-5xl mx-auto px-6 pt-16 pb-12 text-center">
        <div class="mb-4">
            <span class="inline-block px-4 py-1.5 bg-orange-100 text-orange-600 rounded-full text-sm font-semibold">
                Wanna Plai?
            </span>
        </div>

        <h1 class="text-6xl md:text-7xl font-bold tracking-tighter leading-none mb-6">
            Turn Your Lyrics<br>Into Magic
        </h1>
        
        <p class="text-2xl text-zinc-600 max-w-lg mx-auto mb-10">
            Paste your words.<br>
            We’ll turn them into a real song.<br>
            Fast. Fun. Yours.
        </p>

        <button onclick="document.getElementById('create-section').scrollIntoView({ behavior: 'smooth' })" 
                class="px-10 py-4 bg-orange-600 hover:bg-orange-700 transition-all text-white text-xl font-semibold rounded-3xl shadow-lg shadow-orange-600/30 flex items-center gap-x-3 mx-auto">
            Create Your Song <i class="fa-solid fa-arrow-right ml-1"></i>
        </button>
        
        <p class="text-sm text-zinc-500 mt-4">No credit card needed to start</p>
    </div>

    <!-- Create Section -->
    <div id="create-section" class="max-w-6xl mx-auto px-6 pb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            
            <!-- Lyrics Input -->
            <div class="bg-white border border-zinc-200 rounded-3xl p-8 shadow-sm">
                <div class="flex items-center gap-x-3 mb-5">
                    <span class="font-semibold text-xl">Paste your lyrics</span>
                </div>
                
                <textarea id="lyrics-input" rows="7" 
                          class="w-full border border-zinc-300 rounded-2xl p-5 text-lg focus:outline-none focus:border-orange-500 resize-y"
                          placeholder="Write or paste your lyrics here..."></textarea>
                
                <button onclick="generateSong()" 
                        class="mt-5 w-full py-4 bg-black hover:bg-zinc-800 transition-all text-white rounded-2xl font-semibold text-lg flex items-center justify-center gap-x-2">
                    <i class="fa-solid fa-magic"></i>
                    <span>Make It Magical</span>
                </button>
            </div>

            <!-- Song Preview -->
            <div class="bg-white border border-zinc-200 rounded-3xl p-8 shadow-sm">
                <div class="flex items-center justify-between mb-5">
                    <div>
                        <span class="font-semibold text-xl">Your Song</span>
                        <span class="ml-2 text-xs px-3 py-1 bg-orange-100 text-orange-600 rounded-full font-medium">AI Generated</span>
                    </div>
                    <button class="w-14 h-14 bg-orange-600 hover:bg-orange-700 transition-all rounded-full flex items-center justify-center text-white shadow-lg">
                        <i class="fa-solid fa-play text-2xl ml-0.5"></i>
                    </button>
                </div>

                <div class="h-14 bg-zinc-100 rounded-2xl flex items-center px-5 mb-4">
                    <div class="flex-1 h-2.5 bg-gradient-to-r from-pink-500 via-purple-500 to-blue-500 rounded-full relative">
                        <div class="absolute top-1/2 -translate-y-1/2 w-3.5 h-3.5 bg-white border-2 border-zinc-400 rounded-full" style="left: 40%"></div>
                    </div>
                </div>

                <div class="flex justify-between text-xs text-zinc-500 mb-6">
                    <div>0:00</div>
                    <div>3:24</div>
                </div>

                <div class="text-sm text-zinc-                    “
