<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PLAIGROUND • Wanna Plai</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body class="bg-white">
    <!-- Navbar -->
    <nav class="border-b">
        <div class="max-w-6xl mx-auto px-6 py-5 flex justify-between items-center">
            <div class="flex items-center gap-x-3">
                <span class="font-bold text-3xl tracking-tight">PLAIGROUND</span>
            </div>
            <div class="flex items-center gap-x-8 text-sm font-medium">
                <a href="#" class="hover:text-orange-600">Explore</a>
                <a href="#" class="hover:text-orange-600">How it Works</a>
                <button onclick="document.getElementById('create-section').scrollIntoView({ behavior: 'smooth' })" 
                        class="px-6 py-2.5 rounded-2xl bg-black text-white text-sm font-semibold hover:bg-zinc-800">
                    Start Creating
                </button>
            </div>
        </div>
    </nav>

    <!-- Hero -->
    <div class="max-w-5xl mx-auto px-6 pt-16 pb-12 text-center">
        <span class="inline-block px-4 py-1.5 bg-orange-100 text-orange-600 rounded-full text-sm font-semibold mb-4">Wanna Plai?</span>
        <h1 class="text-6xl md:text-7xl font-bold tracking-tighter leading-none mb-6">Turn Your Lyrics<br>Into Magic</h1>
        <p class="text-2xl text-zinc-600 max-w-lg mx-auto mb-10">Paste your words.<br>We’ll turn them into a real song.<br>Fast. Fun. Yours.</p>
        <button onclick="document.getElementById('create-section').scrollIntoView({ behavior: 'smooth' })" 
                class="px-10 py-4 bg-orange-600 hover:bg-orange-700 text-white text-xl font-semibold rounded-3xl shadow-lg flex items-center gap-x-3 mx-auto">
            Create Your Song <i class="fa-solid fa-arrow-right"></i>
        </button>
    </div>

    <!-- Create Section -->
    <div id="create-section" class="max-w-6xl mx-auto px-6 pb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Lyrics Input -->
            <div class="bg-white border border-zinc-200 rounded-3xl p-8">
                <div class="font-semibold text-xl mb-5">Paste your lyrics</div>
                <textarea id="lyrics-input" rows="8" class="w-full border border-zinc-300 rounded-2xl p-5 focus:outline-none focus:border-orange-500" placeholder="Write or paste your lyrics here..."></textarea>
                <button onclick="generateSong()" class="mt-6 w-full py-4 bg-black hover:bg-zinc-800 text-white rounded-2xl font-semibold flex items-center justify-center gap-x-2">
                    <i class="fa-solid fa-magic"></i> Make It Magical
                </button>
            </div>

            <!-- Preview -->
            <div class="bg-white border border-zinc-200 rounded-3xl p-8">
                <div class="flex justify-between mb-5">
                    <div class="font-semibold text-xl">Your Song Preview</div>
                    <button class="w-12 h-12 bg-orange-600 rounded-full flex items-center justify-center text-white">
                        <i class="fa-solid fa-play"></i>
                    </button>
                </div>
                <div class="h-14 bg-zinc-100 rounded-2xl mb-4 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-r from-pink-500 via-purple-500 to-blue-500 opacity-30"></div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function generateSong() {
            alert("✨ Magic happening... (AI integration coming soon!)");
        }
    </script>
</body>
</html>
